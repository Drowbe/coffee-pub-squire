{{#if (eq position "left")}}
    <div class="tray-title-small">
        <span>
            Codex
        </span>
        <div class="codex-toolbar">
            {{#if isGM}}
                <i class="fa-solid fa-bookmark add-codex-button" data-tooltip="Add Codex Entry"></i>
            {{/if}}
            <i class="fa-solid fa-ellipsis-h codex-titlebar-menu" data-tooltip="Codex options"></i>
        </div>
    </div>

    <div class="codex-filters">
        <div class="codex-search">
            <input type="text" placeholder="Search entries..." value="{{filters.search}}">
            <i class="fa-solid fa-times clear-search {{#unless filters.search}}disabled{{/unless}}" title="Clear search"></i>
            <i class="fa-solid fa-filter toggle-tags-button {{#unless isTagCloudCollapsed}}active{{/unless}}" title="Toggle tag filters"></i>
        </div>
        {{#if allTags.length}}
            <div class="codex-tag-cloud {{#if isTagCloudCollapsed}}collapsed{{/if}}">
                {{#each allTags}}
                    <span class="codex-tag {{#if (includes ../filters.tags this)}}selected{{/if}}" data-tag="{{this}}">{{this}}</span>
                {{/each}}
            </div>
        {{/if}}
    </div>

    <div class="codex-content">
        {{#each categoriesData as |cat|}}
            <div class="codex-section {{#if cat.collapsed}}collapsed{{/if}}" data-category="{{cat.name}}">
                <div class="codex-category">
                    <h3>
                        <i class="{{cat.icon}}"></i>
                        {{cat.name}}{{#if cat.entries.length}} <span class="codex-count"> - {{cat.visibleCount}} of {{cat.totalCount}} Discovered </span>{{/if}}
                    </h3>
                    <div class="codex-toolbar">
                        <i class="fa-solid fa-chevron-down" title="Toggle {{cat.name}}"></i>
                    </div>
                </div>
                <div class="codex-entries">
                    {{#each cat.entries as |entry|}}
                        <div class="codex-entry collapsed"
                             data-uuid="{{entry.uuid}}"
                             data-ownership-default="{{entry.ownership.default}}"
                             data-pin-id="{{entry.pinId}}"
                             data-pin-on-scene="{{entry.hasPinOnScene}}">

                            <!-- ENTRY HEADER -->
                            <div class="codex-entry-header">
                                <div class="codex-entry-name" data-tooltip="{{entry.name}}">
                                    {{entry.name}}
                                </div>
                                <div class="codex-toolbar">
                                    {{#if @root.isGM}}
                                        <i class="fa-solid fa-location-dot codex-entry-pin quest-pin-icon {{#if entry.hasPinOnScene}}quest-pin-active{{else}}quest-pin-dim{{/if}}"
                                           data-uuid="{{entry.uuid}}"
                                           data-name="{{entry.name}}"
                                           data-category="{{entry.category}}"
                                           data-has-pin-on-scene="{{entry.hasPinOnScene}}"
                                           title="{{#if entry.hasPinOnScene}}{{#if entry.pinOnActiveScene}}Unplace pin from this scene{{else}}Unplace pin (pinned on {{entry.pinSceneName}}){{/if}}{{else}}Pin to scene{{/if}}"></i>
                                        <i class="fa-solid {{#if (gte entry.ownership.default 2)}}fa-eye codex-entry-visibility visible{{else}}fa-eye codex-entry-visibility{{/if}}"
                                           data-uuid="{{entry.uuid}}"
                                           title="{{#if (gte entry.ownership.default 2)}}Hide from Players{{else}}Show to Players{{/if}}"></i>
                                        <i class="fa-solid fa-ellipsis-h codex-entry-menu"
                                           data-uuid="{{entry.uuid}}"
                                           data-visible="{{gte entry.ownership.default 2}}"
                                           title="Entry options"></i>
                                    {{else}}
                                        <i class="fa-solid fa-feather codex-entry-feather-user" data-uuid="{{entry.uuid}}" title="Open this journal page"></i>
                                    {{/if}}
                                    <i class="fa-solid fa-chevron-right codex-entry-toggle" title="Toggle entry"></i>
                                </div>
                            </div>

                            <!-- ENTRY CONTENT -->
                            <div class="codex-entry-content">

                                <!-- IMAGE -->
                                {{#if entry.img}}
                                    <div class="codex-entry-image">
                                        <img src="{{entry.img}}" alt="{{entry.name}}">
                                    </div>
                                {{/if}}

                                <!-- SUMMARY -->
                                {{#if entry.summary}}
                                    <div class="codex-entry-divider"></div>
                                    <div class="codex-entry-description">
                                        <span class="codex-entry-label">Summary</span>
                                        <p>{{{entry.summary}}}{{#if entry.hasExpandedDetails}} <a class="codex-read-more" data-uuid="{{entry.uuid}}" title="Open the journal page for expanded details">Read more&hellip;</a>{{/if}}</p>
                                    </div>
                                {{/if}}

                                <!-- PLOT HOOK -->
                                {{#if @root.isGM}}
                                    {{#if entry.plotHook}}
                                        <div class="codex-entry-plothook">
                                            <span class="codex-entry-label">Plot Hook</span> 
                                            <p>{{{entry.plotHook}}}</p>
                                        </div>
                                    {{/if}}
                                {{/if}}

                                <!-- LINKS (above location per design) -->
                                {{#if entry.linksHtml.length}}
                                    <div class="codex-entry-link">
                                        <span class="codex-entry-label">{{#if (eq entry.linksHtml.length 1)}}Link{{else}}Links{{/if}}</span>
                                        {{#each entry.linksHtml}}<span class="codex-entry-link-item">{{{this}}}</span>{{/each}}
                                    </div>
                                {{/if}}

                                <!-- LOCATION -->
                                {{#if entry.location}}
                                    <div class="codex-entry-location">
                                        <span class="codex-entry-label">Location</span> {{{entry.location}}}
                                    </div>
                                {{/if}}

                                <!-- DISCOVERED BY -->
                                {{#if entry.DiscoveredBy}}
                                    <div class="codex-entry-discoveredby">
                                        <span class="codex-entry-label">Discovered By</span> {{{entry.DiscoveredBy}}}
                                    </div>
                                {{/if}}

                                <!-- TAGS -->   
                                {{#if entry.tags.length}}
                                    <div class="codex-entry-tags">
                                        {{#each entry.tags}}
                                            <span class="codex-tag {{#if (includes @root.filters.tags this)}}selected{{/if}}" data-tag="{{this}}">{{{this}}}</span>
                                        {{/each}}
                                    </div>
                                {{/if}}
                            </div>
                        </div>
                    {{/each}}
                </div>
            </div>
        {{/each}}
    </div>
{{/if}} 
