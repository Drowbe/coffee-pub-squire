<section class="squire-codex-page-fields squire-codex-page-edit">
    <div class="codex-edit-section-header">
        <i class="fa-solid fa-book-open"></i>
        <span>Codex Fields</span>
    </div>

    <div class="form-group codex-edit-full">
        <label for="{{document.id}}-codex-summary">Summary</label>
        <textarea id="{{document.id}}-codex-summary" name="system.summary" rows="4"
            placeholder="The bite-size card text shown in the Squire tray.">{{system.summary}}</textarea>
    </div>

    <div class="form-group codex-edit-full">
        <label for="{{document.id}}-codex-plothook">Plot Hook <span class="codex-edit-note">(GM only)</span></label>
        <textarea id="{{document.id}}-codex-plothook" name="system.plotHook" rows="2"
            placeholder="How this relates to the plot.">{{system.plotHook}}</textarea>
    </div>

    <div class="codex-edit-grid">
        <div class="form-group">
            <label for="{{document.id}}-codex-category">Category</label>
            <input type="text" id="{{document.id}}-codex-category" name="system.category" value="{{system.category}}"
                placeholder="Characters, Locations, Establishments…">
        </div>
        <div class="form-group">
            <label for="{{document.id}}-codex-location">Location</label>
            <input type="text" id="{{document.id}}-codex-location" name="system.location" value="{{system.location}}"
                placeholder="Faerun &gt; Daggerdale &gt; Dagger Fall">
        </div>
    </div>

    <div class="form-group codex-edit-full">
        <label>Links</label>
        <div class="codex-page-links-edit">
            {{#each linkChips}}
            <span class="codex-link-chip" data-uuid="{{this.uuid}}">
                <i class="fa-solid fa-link"></i><span class="codex-link-chip-label">{{this.label}}</span><i class="fa-solid fa-times codex-link-chip-remove" title="Remove link"></i>
            </span>
            {{/each}}
            <span class="codex-links-hint"><i class="fa-solid fa-hand-pointer"></i> Drag actors, items, journals, or pages here to link them.</span>
        </div>
    </div>

    <div class="form-group codex-edit-full">
        <label for="{{document.id}}-codex-tags">Tags</label>
        <string-tags id="{{document.id}}-codex-tags" name="system.tags" value="{{tagsString}}"></string-tags>
    </div>

    <div class="codex-edit-section-header">
        <i class="fa-solid fa-scroll"></i>
        <span>Expanded Details</span>
    </div>
    <p class="codex-edit-hint">Free-form rich lore, shown on this page below the field block and reachable from the tray via "Read more".</p>
</section>
