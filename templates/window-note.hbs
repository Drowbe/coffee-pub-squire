<div class="blacksmith-window-template-root note-window" data-app-id="{{appId}}">
    <header class="blacksmith-window-template-header note-window-header-shell">
        <div class="blacksmith-window-template-header-content">
            <div class="blacksmith-window-template-header-icon note-window-header-icon" data-tooltip="Configure note pin design">
                {{#if note.iconHtml}}
                    {{{note.iconHtml}}}
                {{else}}
                    <i class="fa-solid fa-note-sticky"></i>
                {{/if}}
            </div>

            <div class="blacksmith-window-template-header-title-block note-window-title-block">
                {{#if isEditMode}}
                    <input type="text" id="title" name="title" class="note-window-title-input" value="{{note.title}}" placeholder="Note title" required>
                {{else}}
                    <div class="blacksmith-window-template-header-title note-window-title-text">{{#if note.title}}{{note.title}}{{else}}Untitled Note{{/if}}</div>
                {{/if}}

                <div class="note-window-meta">
                    <span class="note-window-meta-item note-window-authors">
                        {{#if note.editorAvatars.length}}
                            <span class="note-editor-avatars">
                                {{#each note.editorAvatars}}
                                    <img class="note-editor-avatar" src="{{img}}" title="{{name}}" alt="{{name}}">
                                {{/each}}
                            </span>
                        {{else}}
                            <i class="fa-solid fa-user"></i> {{#if note.authorName}}{{note.authorName}}{{else}}Unknown{{/if}}
                        {{/if}}
                    </span>
                    {{#if note.sceneName}}
                        <span class="note-window-meta-block">
                            <span class="note-window-meta-location">
                                <i class="fa-solid fa-location-dot"></i>
                                {{note.sceneName}}
                            </span>
                            {{#if note.timestamp}}
                                <span class="note-window-meta-date"><i class="fa-solid fa-clock"></i> {{formatTimestamp note.timestamp}}</span>
                            {{else}}
                                <span class="note-window-meta-date"><i class="fa-solid fa-clock"></i> Not saved yet</span>
                            {{/if}}
                        </span>
                    {{else}}
                        {{#if note.timestamp}}
                            <span class="note-window-meta-item"><i class="fa-solid fa-clock"></i> {{formatTimestamp note.timestamp}}</span>
                        {{else}}
                            <span class="note-window-meta-item"><i class="fa-solid fa-clock"></i> Not saved yet</span>
                        {{/if}}
                    {{/if}}
                </div>

                {{#if editLock}}
                    <div class="note-window-editing-indicator" title="{{#if editLock.isSelf}}You are editing{{else}}{{editLock.userName}} is editing{{/if}}">
                        <i class="fa-solid fa-pen-to-square"></i>
                        <span>{{#if editLock.isSelf}}Editing{{else}}Editing: {{editLock.userName}}{{/if}}</span>
                    </div>
                {{/if}}
            </div>

            <div class="blacksmith-window-template-header-right note-window-header-right">
                {{#if isEditing}}
                    <div class="blacksmith-toggle-row" data-tooltip="Toggle between read-only view and note editing.">
                        <span class="blacksmith-toggle-label">Edit</span>
                        <label class="blacksmith-toggle">
                            <input type="checkbox" id="notes-edit-toggle" class="blacksmith-toggle-input" {{#if isEditMode}}checked{{/if}} {{#unless canEdit}}disabled{{/unless}}>
                            <span class="blacksmith-toggle-slider"></span>
                        </label>
                    </div>
                {{/if}}
                <div class="blacksmith-toggle-row" data-tooltip="Private notes remain restricted to the owner until you turn this off.">
                    <span class="blacksmith-toggle-label">Private</span>
                    <label class="blacksmith-toggle">
                        <input type="checkbox" id="notes-visibility-private" class="blacksmith-toggle-input" {{#if (eq note.visibility 'private')}}checked{{/if}} {{#unless isEditMode}}disabled{{/unless}}>
                        <span class="blacksmith-toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>
    </header>

    <div class="blacksmith-window-template-body">
        <section class="note-window-form">
            <input type="hidden" name="sceneId" value="{{note.sceneId}}">
            <input type="hidden" name="x" value="{{note.x}}">
            <input type="hidden" name="y" value="{{note.y}}">
            <input type="hidden" name="pageUuid" value="{{note.pageUuid}}">

            <div class="note-window-main">
                <div class="note-window-content-panel">
                    {{#if isEditMode}}
                        <div class="note-editor-host"></div>
                    {{else}}
                        <div class="note-view-content">{{{note.content}}}</div>
                    {{/if}}
                </div>

                <div class="note-window-tags-panel">
                    {{#if isEditMode}}
                        <div class="note-form-field">
                            <input type="text" id="tags" name="tags" class="note-window-tags-input" value="{{note.tagsText}}" placeholder="npc, phlan, informant">
                            <small class="note-form-hint">Click common tags to add or remove them.</small>
                        </div>
                        {{#if suggestedTags.length}}
                            <div class="note-tag-suggestions-wrap">
                                <div class="note-tag-group-label">Suggested</div>
                                <div class="blacksmith-tags" data-chip-type="tag">
                                    {{#each suggestedTags}}
                                        <span class="blacksmith-tag note-tag-chip {{#if (includes ../note.tags this)}}active{{/if}}" data-tag-value="{{this}}">{{this}}</span>
                                    {{/each}}
                                </div>
                            </div>
                        {{/if}}
                        {{#if commonTags.length}}
                            <div class="note-tag-suggestions-wrap">
                                <div class="note-tag-group-label">Common Tags</div>
                                <div class="blacksmith-tags" data-chip-type="tag">
                                    {{#each commonTags}}
                                        <span class="blacksmith-tag note-tag-chip {{#if (includes ../note.tags this)}}active{{/if}}" data-tag-value="{{this}}">{{this}}</span>
                                    {{/each}}
                                </div>
                            </div>
                        {{/if}}
                    {{else}}
                        <div class="note-view-tags {{#unless note.tags.length}}is-empty{{/unless}}">
                            {{#if note.tags.length}}
                                {{#each note.tags}}
                                    <span class="blacksmith-tag note-view-tag">{{this}}</span>
                                {{/each}}
                            {{else}}
                                <span class="note-view-empty">No tags</span>
                            {{/if}}
                        </div>
                    {{/if}}
                </div>
            </div>
        </section>
    </div>

    <section class="blacksmith-window-template-buttons">
        <div class="blacksmith-window-template-action-bar">
            <div class="blacksmith-window-template-action-left"></div>
            <div class="blacksmith-window-template-action-right">
                <button type="button" class="blacksmith-window-btn-secondary" data-action="cancel">{{#if isEditMode}}Cancel{{else}}Close{{/if}}</button>
                {{#if isEditMode}}
                    <button type="button" class="blacksmith-window-btn-secondary" data-action="savePlace">Save and Place Pin</button>
                    <button type="button" class="blacksmith-window-btn-primary" data-action="save">Save Note</button>
                {{/if}}
            </div>
        </div>
    </section>
</div>
