<div class="blacksmith-window-template-root quest-window" id="{{appId}}">
    <header class="blacksmith-window-template-header">
        <div class="blacksmith-window-template-header-content">
            <div class="blacksmith-window-template-header-icon">
                <i class="fa-solid fa-flag"></i>
            </div>
            <div class="blacksmith-window-template-header-title-block">
                <div class="blacksmith-window-template-header-title quest-window-header-title">{{headerTitle}}</div>
                {{#if subtitle}}
                    <div class="blacksmith-window-template-header-subtitle">{{subtitle}}</div>
                {{/if}}
            </div>
            {{#if isGM}}
                <div class="blacksmith-window-template-header-right">
                    <div class="blacksmith-toggle-row" data-tooltip="Hidden quests remain GM-only until you turn this off.">
                        <span class="blacksmith-toggle-label">Hidden</span>
                        <label class="blacksmith-toggle">
                            <input type="checkbox" id="quest-hidden-toggle" class="blacksmith-toggle-input" {{#unless quest.visible}}checked{{/unless}}>
                            <span class="blacksmith-toggle-slider"></span>
                        </label>
                    </div>
                </div>
            {{/if}}
        </div>
    </header>

    <div class="blacksmith-window-template-body">
        <form class="quest-window-form" method="post">
            <input type="hidden" name="img" value="{{quest.img}}">
            <input type="hidden" name="pageUuid" value="{{quest.pageUuid}}">
            <input type="hidden" name="questUuid" value="{{quest.questUuid}}">

            <section class="blacksmith-window-section quest-drag-section quest-drag-zone">
                <div class="quest-drop-callout">
                    <i class="fa-solid fa-cloud-arrow-up"></i>
                    <div class="quest-drop-copy">
                        <div class="quest-drop-title">{{#if isEditing}}Update From Drop{{else}}Drag & Drop Here{{/if}}</div>
                        <div class="quest-drop-subtitle">Drop actors, items, journal entries, or journal pages to populate participants, treasure, and quest details.</div>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section quest-image-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-image"></i>
                    <span>Image</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-image-preview-wrapper">
                        <div class="quest-image-placeholder">No image selected. Drop a document with artwork or browse for an image.</div>
                        <img class="quest-image-preview" src="" alt="Preview">
                        <button type="button" class="quest-remove-image blacksmith-window-btn-critical" aria-label="Remove image">
                            <i class="fa-solid fa-times"></i>
                        </button>
                    </div>
                    <div class="quest-image-actions">
                        <button type="button" class="blacksmith-window-btn-secondary quest-browse-image">
                            <i class="fa-solid fa-folder-open"></i>
                            <span>Browse Image</span>
                        </button>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-signature"></i>
                    <span>Identity</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-form-grid">
                        <div class="quest-form-field quest-form-field-full">
                            <label for="name">Name (Required)</label>
                            <input type="text" id="name" name="name" value="{{quest.name}}" required>
                        </div>

                        <div class="quest-form-grid quest-form-grid-three">
                            <div class="quest-form-field">
                                <label for="category">Category *</label>
                                <select id="category" name="category" required>
                                    <option value="">Select Category</option>
                                    {{#each existingCategories}}
                                        <option value="{{this}}" {{#if (eq this ../quest.category)}}selected{{/if}}>{{this}}</option>
                                    {{/each}}
                                </select>
                            </div>
                            <div class="quest-form-field">
                                <label for="status">Status (Required)</label>
                                <select id="status" name="status" required>
                                    {{#each statusOptions}}
                                        <option value="{{this.value}}" {{#if (eq this.value ../quest.status)}}selected{{/if}}>{{this.label}}</option>
                                    {{/each}}
                                </select>
                            </div>
                            <div class="quest-form-field">
                                <label for="timeframe-duration">Timeframe</label>
                                <input type="text" id="timeframe-duration" name="timeframe.duration" value="{{quest.timeframe.duration}}" placeholder="e.g. 3 Days">
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-location-dot"></i>
                    <span>World Context</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-form-grid">
                        <div class="quest-form-field quest-form-field-full">
                            <label for="location">Location</label>
                            <select id="location" name="location">
                                <option value="">Select Location</option>
                                <option value="new">+ New Location</option>
                                {{#each existingLocations}}
                                    <option value="{{this}}" {{#if (eq this ../quest.location)}}selected{{/if}}>{{this}}</option>
                                {{/each}}
                            </select>
                        </div>
                        <div class="quest-form-field quest-form-field-full new-location-input-field">
                            <label for="new-location">New Location</label>
                            <input type="text" id="new-location" name="new-location" placeholder="Enter new location">
                        </div>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-scroll"></i>
                    <span>Content</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-form-field">
                        <label for="description">Description</label>
                        <textarea id="description" name="description" rows="4" placeholder="Describe the quest, what is at stake, and any important context...">{{quest.description}}</textarea>
                    </div>

                    <div class="quest-form-field">
                        <label for="plotHook">Plot Hook</label>
                        <textarea id="plotHook" name="plotHook" rows="2" placeholder="Why does the party care? What pushes this quest forward?">{{quest.plotHook}}</textarea>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-list-check"></i>
                    <span>Objectives</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-objectives-list">
                        {{#each objectiveCards}}
                            <div class="quest-objective-card" data-objective-index="{{index}}">
                                <div class="quest-objective-card-title">Objective {{number}}</div>
                                <div class="quest-objective-card-grid">
                                    <div class="quest-form-field quest-objective-description">
                                        <label data-tooltip="Player-facing objective text shown in the quest tray and journal entry.">Description</label>
                                        <input type="text" class="quest-objective-description-input" value="{{description}}" placeholder="Objective description">
                                    </div>
                                    <div class="quest-form-field quest-objective-note">
                                        <label data-tooltip="Optional GM-only context for this objective. This note is not shown to players and can be used for context or hints for the objective.">GM Note</label>
                                        <input type="text" class="quest-objective-note-input" value="{{gmNote}}" placeholder="Optional GM note" data-tooltip="Optional GM-only context for this objective. This note is not shown to players and can be used for context or hints for the objective.">
                                    </div>
                                    <div class="quest-form-field quest-objective-status">
                                        <label data-tooltip="Controls whether the objective is active, complete, failed, or hidden from players.">Status</label>
                                        <select class="quest-objective-status-input">
                                            <option value="active" {{#if (eq status "active")}}selected{{/if}}>Incomplete</option>
                                            <option value="completed" {{#if (eq status "completed")}}selected{{/if}}>Complete</option>
                                            <option value="failed" {{#if (eq status "failed")}}selected{{/if}}>Failed</option>
                                            <option value="hidden" {{#if (eq status "hidden")}}selected{{/if}}>Hidden</option>
                                        </select>
                                    </div>
                                    <div class="quest-form-field quest-objective-treasure">
                                        <label data-tooltip="Optional reward names unlocked by this objective. If a name matches an entry in the Treasure section below, that reward can be treated as gated by completing this objective.">Treasure</label>
                                        <input type="text" class="quest-objective-treasure-input quest-item-drop-target" value="{{treasure}}" data-tooltip="Drop items or type item names here to add them as linked treasure. If the name here martches the name of an item in the Treasure section below, that item can be treated as gated by completing this objective." placeholder="Item names or rewards unlocked" data-drop-mode="objective-treasure">
                                    </div>
                                    <div class="quest-objective-actions">
                                        <div class="quest-objective-actions-left">
                                            <button type="button" class="blacksmith-window-btn-secondary quest-objective-move-btn" data-objective-index="{{index}}" data-move-direction="up" aria-label="Move objective up">
                                                <i class="fa-solid fa-arrow-up"></i>
                                            </button>
                                            <button type="button" class="blacksmith-window-btn-secondary quest-objective-move-btn" data-objective-index="{{index}}" data-move-direction="down" aria-label="Move objective down">
                                                <i class="fa-solid fa-arrow-down"></i>
                                            </button>
                                        </div>
                                        <div class="quest-objective-actions-right">
                                            <button type="button" class="blacksmith-window-btn-secondary quest-objective-current-btn {{#if isCurrent}}is-current{{/if}}" data-objective-index="{{index}}" aria-label="Set current objective" data-current="{{#if isCurrent}}true{{else}}false{{/if}}" data-tooltip="Marks this as the current objective the party is working on. Only one objective can be current at a time.">
                                                <i class="fa-solid fa-bullseye"></i>
                                                <span>{{#if isCurrent}}Current{{else}}Set Current{{/if}}</span>
                                            </button>
                                            <button type="button" class="blacksmith-window-btn-critical quest-objective-delete-btn" data-objective-index="{{index}}" aria-label="Delete objective">
                                                <i class="fa-solid fa-trash"></i>
                                                <span>Delete Objective</span>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {{/each}}
                    </div>
                    <div class="quest-objectives-actions">
                        <button type="button" class="blacksmith-window-btn-secondary quest-add-objective">
                            <i class="fa-solid fa-plus"></i>
                            <span>Add Objective</span>
                        </button>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-sack-dollar"></i>
                    <span>Rewards & Participants</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-form-grid quest-form-grid-two">
                        <div class="quest-form-field">
                            <label for="reward-xp">Experience</label>
                            <input type="number" id="reward-xp" name="reward.xp" value="{{quest.reward.xp}}" min="0" step="1">
                        </div>
                    </div>

                    <div class="quest-form-field">
                        <label for="reward-treasure">Treasure</label>
                        <textarea id="reward-treasure" name="reward.treasure" rows="5" class="quest-item-drop-target" data-drop-mode="reward-treasure" placeholder="One entry per line. Drop items here to add them as linked treasure.">{{treasureText}}</textarea>
                        <small class="quest-form-hint">Dropped items become journal-safe `@UUID[...]` treasure entries.</small>
                    </div>

                    <div class="quest-form-field">
                        <label>Participants</label>
                        <div class="quest-party-members">
                            {{#each partyParticipants}}
                                <label class="quest-party-member {{#if selected}}is-selected{{/if}}" data-actor-uuid="{{uuid}}">
                                    <input type="checkbox" class="quest-party-member-checkbox" value="{{uuid}}" {{#if selected}}checked{{/if}}>
                                    <img src="{{img}}" alt="{{name}}">
                                    <span>{{name}}</span>
                                </label>
                            {{/each}}
                        </div>
                        {{#if extraParticipants.length}}
                            <div class="quest-extra-participants">
                                <div class="quest-tag-group-label">Additional Participants</div>
                                <div class="quest-extra-participant-list">
                                    {{#each extraParticipants}}
                                        <div class="quest-extra-participant" data-extra-index="{{index}}" data-uuid="{{uuid}}" data-name="{{name}}" data-img="{{img}}">
                                            <span>{{name}}</span>
                                            <button type="button" class="quest-extra-participant-remove" data-extra-index="{{index}}" aria-label="Remove participant">
                                                <i class="fa-solid fa-times"></i>
                                            </button>
                                        </div>
                                    {{/each}}
                                </div>
                            </div>
                        {{/if}}
                        <small class="quest-form-hint">Party members can be toggled here. Dropped non-party actors appear as additional participants.</small>
                    </div>
                </div>
            </section>

            <section class="blacksmith-window-section">
                <div class="blacksmith-window-section-header">
                    <i class="fa-solid fa-tags"></i>
                    <span>Classification</span>
                </div>
                <div class="blacksmith-window-section-body">
                    <div class="quest-form-field">
                        <label for="tags">Tags</label>
                        <input type="text" id="tags" name="tags" value="{{#if quest.tags}}{{#if (isArray quest.tags)}}{{quest.tags.join ', '}}{{else}}{{quest.tags}}{{/if}}{{/if}}" placeholder="Enter tags separated by commas">
                    </div>

                    {{#if suggestedTags.length}}
                        <div class="quest-tag-suggestions-wrap">
                            <div class="quest-tag-group-label">Suggested</div>
                            <div class="blacksmith-tags" data-chip-type="tag">
                                {{#each suggestedTags}}
                                    <span class="blacksmith-tag quest-tag-chip {{#if (includes ../quest.tags this)}}active{{/if}}" data-tag-value="{{this}}">{{this}}</span>
                                {{/each}}
                            </div>
                        </div>
                    {{/if}}

                    {{#if otherTags.length}}
                        <div class="quest-tag-suggestions-wrap">
                            <div class="quest-tag-group-label">Other</div>
                            <div class="blacksmith-tags" data-chip-type="tag">
                                {{#each otherTags}}
                                    <span class="blacksmith-tag quest-tag-chip {{#if (includes ../quest.tags this)}}active{{/if}}" data-tag-value="{{this}}">{{this}}</span>
                                {{/each}}
                            </div>
                        </div>
                    {{/if}}
                </div>
            </section>
        </form>
    </div>

    <section class="blacksmith-window-template-buttons">
        <div class="blacksmith-window-template-action-bar">
            <div class="blacksmith-window-template-action-left">
                {{#if isEditing}}
                    <button type="button" class="blacksmith-window-btn-critical" data-action="delete">Delete Quest</button>
                {{/if}}
            </div>
            <div class="blacksmith-window-template-action-right">
                <button type="button" class="blacksmith-window-btn-secondary" data-action="cancel">Cancel</button>
                <button type="button" class="blacksmith-window-btn-primary" data-action="save">{{#if isEditing}}Update Quest{{else}}Save Quest{{/if}}</button>
            </div>
        </div>
    </section>
</div>
